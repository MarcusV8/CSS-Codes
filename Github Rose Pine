      @-moz-document domain("github.com") {
           /* Github */
           :root {
                --C1: #191724;
                --C2: #232136;
                --C3: #393552;
                --C4: #E0DEF4;
                --B1: 1px solid var(--C4);
                --BR1: 15px;
                --BR2: 5px;
                
                --fgColor-muted: var(--C4) !important;
           }
           * {
                color: var(--C4) !important;
           }     
           html, body {
                background-color: var(--C2) !important;           
           }
           input,
           textarea,
           select {
                background-color: var(--C1) !important;
                border-radius: 5px !important;
                color: var(--C4) !important;
           }
           /* Initial Page */
           .feed-content, .AppHeader .AppHeader-globalBar {
                background: var(--C2) !important;
           }
          .feed-item-content, .color-bg-default, .Overlay.Overlay--placement-left, .jBUQU,
           /* Sub Menus */ .overflow-hidden.d-flex.flex-column, .SelectMenu-list, label.SelectMenu-item, .ActionListWrap, .SelectMenu-header, .gAwGiF {
                background: var(--C3) !important;
           }
             .dashboard-break-word,
            /* Buttons */ .AppHeader .AppHeader-button, .Overlay-closeButton, .copilotPreview__footer .copilotPreview__suggestionButton, .details-overlay > summary, .ajax-pagination-form .ajax-pagination-btn, .BtnGroup-parent:last-child .BtnGroup-item, .Button--primary {
                 background: var(--C1) !important;
           }
           /* Tables */
           .markdown-body table tr {
                background: var(--C3) !important;               

           }
           /* Main Page */
           .application-main, .AppHeader .AppHeader-localBar {
               background: var(--C2) !important;
           }
           .fXBJSr, .eIrrGP, .react-directory-row, #selectPanel, .prc-Overlay-Overlay-dVyJl, .prc-Dialog-Dialog-luvDS {
               background: var(--C3) !important;               
           }
           .topic-tag, #\:rq\:, .BtnGroup-item, .dzCJzi, .JMXqM, button, .dJnomT, .coghcP, .jAlLSY th, .bgColor-muted, 
          .OverviewRepoFiles-module__Box_3--Bi2jM, .FileResultsList-module__FilesSearchBox--J5FtW {
               background: var(--C1) !important;
           }
           .markdown-body .highlight pre, .markdown-body pre, .markdown-body .highlight, .js-snippet-clipboard-copy-unpositioned .markdown-body .snippet-clipboard-content, .js-snippet-clipboard-copy-unpositioned .markdown-body .highlight {
               background: var(--C3) !important;
               border-radius: var(--BR1);
           }
           /* Issues */
           .ListItemsHeaderWithoutBulkActions-module__ListViewMetadata_0--x0baS, [href]:where(.prc-Button-ButtonBase-c50BI), .Box-header, .subnav-item, .gOHzTT, .gxwXUv, .bqJEpA {
               background: var(--C1) !important;           
           }
           .LayoutHelpers-module__timelineElement--tFGhF, .gRssIw, .bORxqf, .dxnHPp{
                background: var(--C2) !important;  
           }
           .rNmmh, .Box-row--focus-gray.navigation-focus, .crMLA-D {
               background: var(--C3) !important;           
           }
           .text-light, .d-flex.flex-justify-center.flex-items-center.flex-column-reverse.flex-lg-row.flex-wrap.flex-lg-nowrap {
               display: none !important;
           }
           /* Projects */
           .Box, .menu {
               background: var(--C3) !important;
           }
           /* Wiki */
           .gh-header {
                background: var(--C2) !important;
           }
           .ClipboardButton, .Button--secondary {
               background: var(--C1) !important;
           }
           /* Search */
           .color-bg-subtle {
               background: var(--C1) !important;
           }
      }   
