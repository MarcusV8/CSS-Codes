 @-moz-document domain("chatgpt.com") {
           /* Chatgpt*/
           :root {
                --C1: #191724;
                --C2: #232136;
                --C3: #393552;
                --C4: #E0DEF4;
                --B1: 1px solid var(--C4);
                --BR1: 15px;
                --BR2: 5px;
           }
           * {
                color: var(--C4) !important;
           }
           /* ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■/  Main Page  /■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■*/
           
           body,
           .bg-token-main-surface-primary:not([id*="radix"]), .bg-token-bg-primary, #search {
                background-color: var(--C2) !important;
           }
           .bg-token-sidebar-surface-primary, .rounded-full, .bg-\[var\(--item-background-color\)\],
           .dark\:hover\:bg-gray-700, .bg-blue-400, .dark\:bg-token-main-surface-tertiary:is(.dark *)  {
                background-color: var(--C1);
           }
           
           /* ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■/  Sub Menu  /■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■*/
           
           .max-h-\[var\(--radix-dropdown-menu-content-available-height\)\].overflow-y-auto.py-2.min-w-fit,
           #radix-\:raj\:, .bg-token-bg-elevated-secondary,
           #radix-\:r44\:, .py-3, [role="menu"], #stage-slideover-sidebar, .group\/scrollport.relative.flex.h-full.w-full.flex-1.flex-col.overflow-y-auto.transition-opacity.duration-500,
     .bg-token-bg-primary.flex.w-full.cursor-text.flex-col.items-center.justify-center.overflow-clip.bg-clip-padding.contain-inline-size.dark\:bg-\[\#303030\].shadow-short.rounded-\[28px\],
     .shadow-long:is(.dark *) {
                background-color: var(--C3) !important;
           }
           
           /* ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■/  Buttons  /■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■*/
           
          .rounded-full:not(:has(> button:nth-child(1))), .btn-secondary, .btn-primary, .btn-danger, .hover\:bg-token-main-surface-secondary:hover, #system-hint-button, .composer-btn[data-pill] {
                background-color: var(--C1) !important;
           }
           .dark\:bg-gray-700:is(.dark *), .md\:radix-state-active\:bg-token-main-surface-secondary[data-state="active"], code:not([class*="language-"]) {
               background-color: var(--C3) !important;
           }
           [aria-label="Botão de ditado"], #upload-file-btn {
               background-color: var(--C1) !important;
               border-radius: 50%;
           }
               #system-hint-button, .composer-btn[data-pill] {
                    border-radius: var(--BR1);
                      margin-left: 8px;
           }
           .contextual-discovery-response-promotion {
                   border-radius: var(--BR1) !important;
           }
           
           /* ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■/  Message & Secondary Elements  /■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■*/
          
          .bg-token-message-surface,
           .flex.items-center.rounded.bg-token-sidebar-surface-primary.px-2.font-sans.text-xs.text-token-text-secondary.dark\:bg-token-main-surface-secondary,
           #composer-background {
                background-color: var(--C3) !important;
           }
           .dark\:bg-token-main-surface-secondary:is(.dark *),
           .flex.items-center.text-token-text-secondary.px-4.py-2.text-xs.font-sans.justify-between.rounded-t-md.h-9.bg-token-sidebar-surface-primary.dark\:bg-token-main-surface-secondary.select-none {
                background-color: var(--C1) !important;
           }
           
           /* ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■/  Declutter Page  /■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■*/
           
           .group.flex.gap-2.p-2\.5.text-sm.cursor-pointer.focus\:ring-0.radix-disabled\:pointer-events-none.radix-disabled\:opacity-50.items-center.hover\:bg-token-sidebar-surface-secondary.screen-arch\:px-2.screen-arch\:py-1\.5.screen-arch\:min-h-\[47px\].rounded-lg.m-0.px-2,
           [dir="ltr"] .\@lg\/thread\:left-0,
           .md\:px-\[60px\], .content-fade::after, .group.__menu-item.hoverable.gap-2, .flex.items-center.gap-1\.5.rounded-full.bg-\[\#F1F1FB\].py-1\.5.ps-3.pe-3\.5.text-sm.font-medium.text-\[\#5D5BD0\].hover\:bg-\[\#E4E4F6\].dark\:bg-\[\#373669\].dark\:text-\[\#DCDBF6\].dark\:hover\:bg-\[\#414071\] {
                    display: none;
           }
  
         /* ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■/  Width /■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■*/
        
        .h-full.max-w-full.overflow-hidden > main article:has(.group\/conversation-turn) .md\:max-w-3xl {
            max-width: var(--mw);
            --mw: 100%;

            @media screen and (min-width: 768px) { --mw: max(48rem, 85%) !important; }
            @media screen and (min-width: 1024px) { --mw: 80% !important; }
            @media screen and (min-width: 1536px) { --mw: 70% !important; }
        }
    }

