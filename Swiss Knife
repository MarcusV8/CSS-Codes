        GM_addStyle(helpPanelCSS);

        function createHelpPanelHTML() {
            const rectStatus = typeof window.combinedScript_isRectEnabled === 'function' && window.combinedScript_isRectEnabled() ? 'ATIVADO' : 'DESATIVADO';
            const inspectorStatus = typeof window.combinedScript_isInspectorEnabled === 'function' && window.combinedScript_isInspectorEnabled() ? 'ATIVO' : 'INATIVO';
            const customBindingsStatus = isCustomBindingsEnabled ? 'ATIVADO' : 'DESATIVADO';
            const doubleClickImageStatus = isDoubleClickImageDownloaderEnabled ? 'ATIVADO' : 'DESATIVADO';

            return `
                <h2>Atalhos - Swiss Knife Script</h2>
                <ul>
                    <li><span class="shortcut-keys"><kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>*</kbd></span><span class="shortcut-desc">Ativar/Desativar Inspetor de Elementos (Atual: ${inspectorStatus})</span></li>
                    <li><span class="shortcut-keys"><kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>U</kbd></span><span class="shortcut-desc">Copiar Seletor CSS (Inspetor deve estar ativo)</span></li>
                    <li><span class="shortcut-keys"><kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>-</kbd></span><span class="shortcut-desc">Alternar Seleção por Retângulo (Atual: ${rectStatus})</span></li>
                    <li><span class="shortcut-keys"><kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>/</kbd></span><span class="shortcut-desc">Alternar Custom Bindings (Atual: ${customBindingsStatus})</span></li>
                    <li><span class="shortcut-keys"><kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>+</kbd></span><span class="shortcut-desc">Alternar Double-click Image Downloader (Atual: ${doubleClickImageStatus})</span></li>
                    <li><span class="shortcut-keys"><kbd>Botão Direito</kbd></span><span class="shortcut-desc">(Sobre um link) Abrir em Nova Aba</span></li>
                    <li><span class="shortcut-keys"><kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>Enter</kbd></span><span class="shortcut-desc">Mostrar/Esconder este Painel de Ajuda</span></li>
                    <li><span class="shortcut-keys"><kbd>Qualquer Tecla</kbd></span><span class="shortcut-desc">Mostrar Cursor (se oculto)</span></li>
                </ul>
                <p class="close-instruction">Pressione <kbd>Esc</kbd> ou <kbd>Ctrl</kbd>+<kbd>Shift</kbd>+<kbd>Enter</kbd> para fechar.</p>
            `;
        }

        function ensureHelpPanelElement() {
            if (!helpPanelElement || !document.body.contains(helpPanelElement)) {
                helpPanelElement = document.getElementById(HELP_PANEL_ID);
                if (!helpPanelElement) {
                    helpPanelElement = document.createElement('div');
                    helpPanelElement.id = HELP_PANEL_ID;
                    if (document.body) {
                        document.body.appendChild(helpPanelElement);
                    } else {
                        document.addEventListener('DOMContentLoaded', () => {
                            if (!document.getElementById(HELP_PANEL_ID)) {
                                document.body.appendChild(helpPanelElement);
                            }
                        });
                    }
                }
            }
            if (helpPanelElement) {
                helpPanelElement.innerHTML = createHelpPanelHTML();
            }
        }

        function toggleHelpPanel() {
            ensureHelpPanelElement();
            if (!helpPanelElement) return;

            isHelpPanelVisible = !isHelpPanelVisible;
            if (isHelpPanelVisible) {
                helpPanelElement.classList.add('visible');
            } else {
                helpPanelElement.classList.remove('visible');
            }
        }
        window.combinedScript_toggleHelpPanel = toggleHelpPanel;
        window.combinedScript_isHelpPanelVisible = () => isHelpPanelVisible;
    })();

    // ========================================================================
    // Bloco Geral: Listener de Teclado Unificado
    // ========================================================================
    window.addEventListener('keydown', (e) => {
        let shortcutProcessed = false;

        if (e.ctrlKey && e.shiftKey && e.key === 'Enter') {
            if (typeof window.combinedScript_toggleHelpPanel === 'function') {
                e.preventDefault();
                window.combinedScript_toggleHelpPanel();
                shortcutProcessed = true;
            }
        } else if (e.key === 'Escape') {
            if (typeof window.combinedScript_isHelpPanelVisible === 'function' && window.combinedScript_isHelpPanelVisible() && typeof window.combinedScript_toggleHelpPanel === 'function') {
                e.preventDefault();
                window.combinedScript_toggleHelpPanel();
                shortcutProcessed = true;
            }
        } else if (e.ctrlKey && e.shiftKey && e.key === '*') {
            if (typeof window.combinedScript_toggleInspector === 'function') {
                e.preventDefault();
                window.combinedScript_toggleInspector();
                shortcutProcessed = true;
            }
        } else if (e.ctrlKey && e.shiftKey && e.key === 'U') {
            if (typeof window.combinedScript_isInspectorEnabled === 'function' && window.combinedScript_isInspectorEnabled() && typeof window.combinedScript_copyCurrentSelector === 'function') {
                e.preventDefault();
                if (window.combinedScript_copyCurrentSelector()) {
                    const inspectorPanel = typeof window.combinedScript_getInspectorPanel === 'function' ? window.combinedScript_getInspectorPanel() : null;
                    if (inspectorPanel) {
                        const copyBtn = inspectorPanel.querySelector('.class-copy');
                        if (copyBtn && !copyBtn.textContent.includes('✓')) {
                            const originalText = copyBtn.textContent;
                            const originalTitle = copyBtn.title;
                            copyBtn.textContent = '✓ Copiado!';
                            copyBtn.title = 'Seletor copiado!';
                            setTimeout(() => {
                                if (copyBtn && copyBtn.textContent === '✓ Copiado!') {
                                    copyBtn.textContent = originalText;
                                    copyBtn.title = originalTitle;
                                }
                            }, 1500);
                        }
                    }
                    if (typeof showStatusMessage === 'function') {
                        showStatusMessage('Seletor CSS copiado!');
                    }
                } else {
                    if (typeof showStatusMessage === 'function') {
                        showStatusMessage('Não foi possível copiar o seletor.');
                    }
                }
                shortcutProcessed = true;
            }
        } else if (e.ctrlKey && e.shiftKey && e.key === '-') {
            if (typeof window.combinedScript_toggleRectScriptState === 'function') {
                e.preventDefault();
                window.combinedScript_toggleRectScriptState();
                shortcutProcessed = true;
            }
        } else if (e.ctrlKey && e.shiftKey && e.key === '/') {
            isCustomBindingsEnabled = !isCustomBindingsEnabled;
            const statusText = isCustomBindingsEnabled ? 'ATIVADO' : 'DESATIVADO';
            if (typeof showStatusMessage === 'function') {
                showStatusMessage(`Custom Bindings: ${statusText}`);
            }
            e.preventDefault();
            shortcutProcessed = true;
        } else if (e.ctrlKey && e.shiftKey && e.key === '+') {
            isDoubleClickImageDownloaderEnabled = !isDoubleClickImageDownloaderEnabled;
            const statusText = isDoubleClickImageDownloaderEnabled ? 'ATIVADO' : 'DESATIVADO';
            if (typeof showStatusMessage === 'function') {
                showStatusMessage(`Double-click Image Downloader: ${statusText}`);
            }
            e.preventDefault();
            shortcutProcessed = true;
        }
        if (!shortcutProcessed && typeof window.combinedScript_resetCursor === 'function') {
            window.combinedScript_resetCursor();
        }
    }, true);
})();
