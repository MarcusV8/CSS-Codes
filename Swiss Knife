                color: #fff !important;
                padding: 10px !important;
                border-radius: 5px !important;
                z-index: 2147483647 !important;
                max-width: 300px !important;
                font-family: monospace !important;
                font-size: 12px !important;
                pointer-events: none !important;
                display: none !important;
                box-sizing: border-box !important;
                margin: 0 !important;
                line-height: 1.2 !important;
                text-align: left !important;
                word-wrap: break-word !important;
            }
            .hover-debug-panel.tampermonkey-element-inspector * {
                all: initial !important;
                font-family: monospace !important;
                font-size: 12px !important;
                color: #fff !important;
                margin: 0 !important;
                padding: 0 !important;
                line-height: 1.2 !important;
                box-sizing: border-box !important;
                text-align: left !important;
                background: none !important;
                border: none !important;
                word-wrap: normal !important;
            }
            .hover-debug-panel.tampermonkey-element-inspector .class-copy {
                cursor: pointer !important;
                color: #7fffd4 !important;
                text-decoration: underline !important;
                pointer-events: auto !important;
                display: inline-block !important;
                margin-top: 5px !important;
            }
            .hover-debug-panel.tampermonkey-element-inspector.inspector-active {
                border-color: #00ff00 !important;
                display: block !important;
            }
            .hover-debug-panel.tampermonkey-element-inspector strong {
                font-weight: bold !important;
                margin-right: 5px !important;
            }
            .hover-debug-panel.tampermonkey-element-inspector hr {
                border: none !important;
                border-top: 1px solid #555 !important;
                margin: 5px 0 !important;
                height: 1px !important;
            }
        `;
        GM_addStyle(inspectorStyles);

        function createInspectorPanel() {
            if (inspectorPanel) return inspectorPanel;
            inspectorPanel = document.createElement('div');
            inspectorPanel.className = 'hover-debug-panel tampermonkey-element-inspector';
            document.body.appendChild(inspectorPanel);
            return inspectorPanel;
        }

        function formatElementClasses(classString) {
            return classString && typeof classString === 'string' && classString.trim() !== '' ?
                `.${classString.trim().replace(/\s+/g, '.')}` : '';
        }

        function captureElementStyles(element) {
            try {
                if (!(element instanceof Element)) return { backgroundColor: 'N/A', color: 'N/A', border: 'N/A' };
                const style = window.getComputedStyle(element);
                return { backgroundColor: style.backgroundColor, color: style.color, border: style.border };
            } catch (e) {
                return { backgroundColor: 'error', color: 'error', border: 'error' };
            }
        }

        function updateInspectorPanel(target) {
            if (!inspectorPanel || !target) return;
            const preHoverStyles = captureElementStyles(target);
            const tagName = target.tagName ? target.tagName.toLowerCase() : '[não é elemento]';
            const elementId = target.id ? `#${target.id}` : '';
            const formattedClasses = formatElementClasses(target.className);
            const selectorToCopy = `${tagName}${elementId}${formattedClasses}` || tagName;
            const info = `<strong>Tag:</strong> ${tagName}${elementId ? `<br><strong>ID:</strong> ${elementId}` : ''}${formattedClasses ? `<br><strong>Classes:</strong> ${formattedClasses}` : '<br><strong>Classes:</strong> [Nenhuma]'}<div class="class-copy" title="Copiar seletor (${selectorToCopy})">⎘ Copiar seletor</div><hr><strong>Estilos Computados:</strong><div>BG: ${preHoverStyles.backgroundColor}</div><div>Cor: ${preHoverStyles.color}</div><div>Borda: ${preHoverStyles.border}</div>`;
            inspectorPanel.innerHTML = info;
            inspectorPanel.classList.add('inspector-active');
        }

        function handleInspectorMouseMove(e) {
            if (!inspectorEnabled) return;
            const target = e.target;
            if (!target || target === inspectorCurrentTarget || target.closest('.tampermonkey-element-inspector, #link-selector-status-message, #swissknife-help-panel')) {
                return;
            }
            inspectorCurrentTarget = target;
            updateInspectorPanel(target);
        }

        function copyCurrentSelectorToClipboard() {
            if (inspectorCurrentTarget) {
                const tagName = inspectorCurrentTarget.tagName ? inspectorCurrentTarget.tagName.toLowerCase() : '';
                if ((tagName === 'body' || tagName === 'html') && !inspectorCurrentTarget.id && !formatElementClasses(inspectorCurrentTarget.className)) return false;
                const elementId = inspectorCurrentTarget.id ? `#${inspectorCurrentTarget.id}` : '';
                const formattedClasses = formatElementClasses(inspectorCurrentTarget.className);
                const selectorToCopy = `${tagName}${elementId}${formattedClasses}` || tagName;
                if (selectorToCopy) {
                    GM_setClipboard(selectorToCopy);
                    return true;
                }
            }
            return false;
        }

        function handleInspectorPanelClick(e) {
            if (e.target.classList.contains('class-copy')) {
                if (copyCurrentSelectorToClipboard() && inspectorPanel) {
                    const copyBtn = e.target;
                    const originalText = '⎘ Copiar seletor';
                    copyBtn.textContent = '✓ Copiado!';
                    setTimeout(() => {
                        if (copyBtn && copyBtn.textContent === '✓ Copiado!') copyBtn.textContent = originalText;
                    }, 1500);
                }
            }
        }

        function toggleInspector() {
            inspectorEnabled = !inspectorEnabled;
            const statusText = inspectorEnabled ? 'ATIVADO' : 'DESATIVADO';
            if (typeof showStatusMessage === 'function') {
                showStatusMessage(`Inspetor de Elementos: ${statusText}`);
            }

            if (inspectorEnabled) {
                createInspectorPanel();
                document.addEventListener('mousemove', handleInspectorMouseMove, true);
                document.addEventListener('click', handleInspectorPanelClick, true);
            } else {
                document.removeEventListener('mousemove', handleInspectorMouseMove, true);
                document.removeEventListener('click', handleInspectorPanelClick, true);
                if (inspectorPanel) {
                    inspectorPanel.innerHTML = '';
                    inspectorPanel.classList.remove('inspector-active');
                }
                inspectorCurrentTarget = null;
            }
        }

        window.combinedScript_toggleInspector = toggleInspector;
        window.combinedScript_isInspectorEnabled = () => inspectorEnabled;
        window.combinedScript_copyCurrentSelector = copyCurrentSelectorToClipboard;
        window.combinedScript_getInspectorPanel = () => inspectorPanel;
    })();

    // ========================================================================
    // Bloco 4: Funcionalidade "Stop videos looping"
    // ========================================================================
    (function() {
        const hostname = window.location.hostname;
        if (hostname === 'music.youtube.com' || hostname === 'open.spotify.com') {
            return;
        }

        const processedVideos = new WeakSet();

        const init = () => {
            const vids = document.querySelectorAll("video");
            vids.forEach((vid) => {
                if (processedVideos.has(vid)) return;
                processedVideos.add(vid);
                vid.removeAttribute("loop");
                let arr = [];

                const setupTimeout = (extra = 0) => {
                    let vidLen = vid.duration;
                    let vidCurr = vid.currentTime;

                    if ((vidLen - vidCurr) * 1000 < 500) return;
                    if (isNaN(vid.duration) || vid.duration === Infinity) return;

                    if (vidLen > vidCurr) {
                        const timeout = setTimeout(() => {
                            vidLen = vid.duration;
                            vidCurr = vid.currentTime;
                            const remaining = (vidLen - vidCurr) * 1000;
                            if (remaining < 500) vid.pause();
                        }, (vidLen - vidCurr - 0.01) * 1000 + extra);
                        arr.push(timeout);
                    }
                };

                vid.addEventListener('loadedmetadata', () => setupTimeout(-200));

                vid.addEventListener('seeked', () => {
                    clearAll(arr);
                    setupTimeout();
                });

                vid.addEventListener("pause", () => {
                    clearAll(arr);
                });

                vid.addEventListener("play", () => {
                    setupTimeout();
                });

                vid.addEventListener("ended", () => {
                    setTimeout(() => vid.pause(), 10);
                });
            });
        };
        const clearAll = (arr) => {
            arr.forEach((timeout) => {
                clearTimeout(timeout);
            });
            arr.length = 0;
        };
        const observer = new MutationObserver(init);
        observer.observe(document.body, { childList: true, subtree: true });
        init();
    })();

    // ========================================================================
    // Bloco 5: Funcionalidade "Double-click Image Downloader"
    // ========================================================================
    (function() {
        function filterFilename(name) {
            return /^.+\.(?:jpe?g|png|gif|webp|avif)$/iu.exec(name)?.[0];
        }

        function readFilename(url) {
            const pathname = url.pathname;
            const leaf = pathname.slice(pathname.lastIndexOf('/') + 1);
            return filterFilename(leaf);
        }

        async function onDoubleClick(dblClick) {
            if (!isDoubleClickImageDownloaderEnabled) return;
            if (dblClick.target.nodeName === 'IMG') {
                const imageElement = dblClick.target;
                if (!imageElement.src || imageElement.src.startsWith('data:')) {
                    console.log('[ImageDownloader Generic] Imagem sem URL válida ou é base64');
                    return;
                }
                const imageUrl = new URL(imageElement.src, window.location.origin);
                let filename = readFilename(imageUrl);
                if (!filename) {
                    const parts = imageUrl.pathname.split('/');
                    let defaultName = parts.at(-1) || 'image';
                    let extension = 'jpg';
                    if (imageUrl.pathname.includes('.webp')) extension = 'webp';
                    else if (imageUrl.pathname.includes('.png')) extension = 'png';
                    else if (imageUrl.pathname.includes('.gif')) extension = 'gif';
                    else if (imageUrl.pathname.includes('.avif')) extension = 'avif';
                    if (!defaultName.includes('.')) defaultName += '.' + extension;
                    filename = filterFilename(defaultName) || 'image.' + extension;
                }
                GM_download({
                    url: imageUrl.href,
                    name: filename
                });
            }
        }

        function initialize() {
            console.log('[ImageDownloader Generic] Inicializado!');
            document.body.addEventListener('dblclick', onDoubleClick);
        }

        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initialize);
        else initialize();
    })();

