// ==UserScript==
// @name         Swiss Knife
// @namespace    http://tampermonkey.net/
// @version      1.5
// @description  Combina funcionalidades: Abrir link com botão direito, esconder cursor, Element Inspector, Abrir links com retângulo, Painel de Ajuda, Stop videos looping e Double-click Image Downloader.
// @match        *://*/*
// @grant        GM_addStyle
// @grant        GM_setClipboard
// @grant        GM_openInTab
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_info
// @grant        GM_download
// @icon         https://raw.githubusercontent.com/MarcusV8/Icons/refs/heads/main/Swiss.png
// ==/UserScript==

(function() {
    'use strict';

    let isCustomBindingsEnabled = true;
    let isDoubleClickImageDownloaderEnabled = true;

    // ========================================================================
    // Bloco 1: Funcionalidades de "Custom Bindings"
    // ========================================================================
    (function() {
        document.addEventListener('contextmenu', function(event) {
            if (!isCustomBindingsEnabled) return;
            const link = event.target.closest('a');
            if (link && link.href) {
                event.preventDefault();
                window.open(link.href, '_blank');
            }
        }, false);

        let hideCursorTimeoutId;
        const hideCursor = () => {
            if (!isCustomBindingsEnabled) return;
            if (document.body) document.body.style.cursor = 'none';
        };
        const resetCursor = () => {
            clearTimeout(hideCursorTimeoutId);
            if (document.body) {
                if (document.body.style.cursor === 'none') document.body.style.cursor = '';
                if (isCustomBindingsEnabled) hideCursorTimeoutId = setTimeout(hideCursor, 3000);
            }
        };
        document.addEventListener('mousemove', resetCursor, { passive: true });
        resetCursor();
        window.combinedScript_resetCursor = resetCursor;
    })();

    // ========================================================================
    // Bloco 2: Funcionalidade "Abrir Links com Retângulo"
    // ========================================================================
    let showStatusMessage;
    (function() {
        const RECT_STORAGE_KEY = 'linkRectangleSelectorEnabled';
        const RECT_MAX_LINKS_NO_CONFIRM = 10;
        const RECT_IGNORE_PARENT_TAGS = ['nav', 'footer', 'aside', 'header', '.fl', '.uyS0S', '.dM1Yyd, .dEEN8c'];
        const RECT_TOGGLE_SHORTCUT = { ctrl: true, shift: true, key: '-' };

        let isRectScriptEnabled = GM_getValue(RECT_STORAGE_KEY, true);

        const rectSelectorStyles = `
            #link-selector-rectangle {
                position: absolute;
                border: 1px dashed #4682b4;
                background-color: rgba(70, 130, 180, 0.15);
                z-index: 2147483646;
                pointer-events: none;
                display: none;
                box-sizing: border-box;
            }
        `;
        const rectStatusMessageStyles = `
            #link-selector-status-message {
                position: fixed !important;
                bottom: 15px !important;
                right: 15px !important;
                background-color: rgba(57, 53, 82, 0.95) !important;
                color: white !important;
                padding: 8px 15px !important;
                border-radius: 8px !important;
                z-index: 2147483647 !important;
                font-family: sans-serif !important;
                font-size: 13px !important;
                opacity: 0 !important;
                transition: opacity 0.4s ease-out !important;
                pointer-events: none !important;
                box-shadow: 0 2px 5px rgba(0,0,0,0.3) !important;
            }
            #link-selector-status-message.visible { opacity: 1 !important; }
        `;
        GM_addStyle(rectSelectorStyles + rectStatusMessageStyles);

        let selectionDiv = document.createElement('div');
        selectionDiv.id = 'link-selector-rectangle';
        document.body.appendChild(selectionDiv);
        let statusMessageDiv = null;
        let statusMessageTimeout = null;
        let isDrawingRect = false;
        let rectStartX, rectStartY;

        showStatusMessage = function(message) {
            if (!statusMessageDiv) {
                statusMessageDiv = document.createElement('div');
                statusMessageDiv.id = 'link-selector-status-message';
                if (document.body) {
                    document.body.appendChild(statusMessageDiv);
                } else {
                    document.addEventListener('DOMContentLoaded', () => {
                        if (!document.getElementById('link-selector-status-message')) {
                            document.body.appendChild(statusMessageDiv);
                        }
                    });
                }
            }
            if (statusMessageDiv && document.body.contains(statusMessageDiv)) {
                statusMessageDiv.textContent = message;
                statusMessageDiv.classList.add('visible');
                if (statusMessageTimeout) clearTimeout(statusMessageTimeout);
                statusMessageTimeout = setTimeout(() => {
                    if (statusMessageDiv) statusMessageDiv.classList.remove('visible');
                    statusMessageTimeout = null;
                }, 2500);
            } else if (statusMessageDiv && !document.body.contains(statusMessageDiv)) {
                document.body.appendChild(statusMessageDiv);
                statusMessageDiv.textContent = message;
                statusMessageDiv.classList.add('visible');
                if (statusMessageTimeout) clearTimeout(statusMessageTimeout);
                statusMessageTimeout = setTimeout(() => {
                    if (statusMessageDiv) statusMessageDiv.classList.remove('visible');
                    statusMessageTimeout = null;
                }, 2500);
            }
        }

        function toggleRectScriptState() {
            isRectScriptEnabled = !isRectScriptEnabled;
            GM_setValue(RECT_STORAGE_KEY, isRectScriptEnabled);
            const statusText = isRectScriptEnabled ? 'ATIVADO' : 'DESATIVADO';
            showStatusMessage(`Seleção de Links (Retângulo): ${statusText}`);
        }

        document.addEventListener('mousedown', (e) => {
            if (!isRectScriptEnabled) return;
            const ignoredElements = 'a, button, input, textarea, select, label, [role="button"], [role="link"], [contenteditable="true"], summary, details, .hover-debug-panel, #link-selector-status-message, #swissknife-help-panel';
            if (e.button !== 0 || e.target.closest(ignoredElements)) return;
            e.preventDefault();
            e.stopPropagation();
            isDrawingRect = true;
            rectStartX = e.pageX;
            rectStartY = e.pageY;
            selectionDiv.style.left = rectStartX + 'px';
            selectionDiv.style.top = rectStartY + 'px';
            selectionDiv.style.width = '0px';
            selectionDiv.style.height = '0px';
            selectionDiv.style.display = 'block';
        }, true);

        document.addEventListener('mousemove', (e) => {
            if (!isDrawingRect) return;
            let currentX = e.pageX;
            let currentY = e.pageY;
            let left = Math.min(rectStartX, currentX);
            let top = Math.min(rectStartY, currentY);
            let width = Math.abs(currentX - rectStartX);
            let height = Math.abs(currentY - rectStartY);
            selectionDiv.style.left = left + 'px';
            selectionDiv.style.top = top + 'px';
            selectionDiv.style.width = width + 'px';
            selectionDiv.style.height = height + 'px';
        }, true);

        document.addEventListener('mouseup', (e) => {
            if (!isDrawingRect) return;
            isDrawingRect = false;
            selectionDiv.style.display = 'none';
            const rect = {
                left: parseInt(selectionDiv.style.left, 10),
                top: parseInt(selectionDiv.style.top, 10),
                width: parseInt(selectionDiv.style.width, 10),
                height: parseInt(selectionDiv.style.height, 10),
                right: 0,
                bottom: 0
            };
            rect.right = rect.left + rect.width;
            rect.bottom = rect.top + rect.height;
            if (rect.width < 10 && rect.height < 10) return;

            const potentialLinks = document.querySelectorAll('a[href^="http"]');
            const linksToOpen = new Set();
            const ignoreSelector = RECT_IGNORE_PARENT_TAGS.join(', ');

            potentialLinks.forEach(link => {
                const linkRect = link.getBoundingClientRect();
                if (linkRect.width === 0 || linkRect.height === 0 || link.offsetParent === null) return;
                if (ignoreSelector && link.closest(ignoreSelector)) return;
                const linkPageRect = {
                    left: linkRect.left + window.scrollX,
                    top: linkRect.top + window.scrollY,
                    right: linkRect.right + window.scrollX,
                    bottom: linkRect.bottom + window.scrollY
                };
                const intersects = (
                    linkPageRect.left < rect.right &&
                    linkPageRect.right > rect.left &&
                    linkPageRect.top < rect.bottom &&
                    linkPageRect.bottom > rect.top
                );
                if (intersects) linksToOpen.add(link.href);
            });

            if (linksToOpen.size > 0) {
                let confirmOpen = true;
                if (linksToOpen.size > RECT_MAX_LINKS_NO_CONFIRM) {
                    confirmOpen = confirm(`Você selecionou ${linksToOpen.size} links neste retângulo.\n\nDeseja realmente abrir todos em novas abas?`);
                }
                if (confirmOpen) {
                    linksToOpen.forEach(href => {
                        GM_openInTab(href, { active: false, insert: true });
                    });
                }
            }
        }, true);

        window.combinedScript_toggleRectScriptState = toggleRectScriptState;
        window.combinedScript_isRectEnabled = () => isRectScriptEnabled;
    })();

